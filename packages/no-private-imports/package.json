  "devDependencies": {
    "@biomejs/biome": "catalog:dev",
    "@types/jest": "catalog:dev",
    "@types/node": "catalog:dev",
    "jest": "catalog:dev",
    "ts-jest": "catalog:dev",
    "typescript": "catalog:peer"
  },
  "peerDependencies": {
    "typescript": "catalog:peer"
  },
