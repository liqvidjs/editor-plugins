{
  "name": "no-private-imports",
  "version": "0.0.1",
  "description": "TypeScript plugin for export scoping",
  "repository": {
    "type": "git",
    "url": "git@github.com:liqvidjs/editor-plugins.git",
    "directory": "packages/no-private-imports"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "pnpm build:clean && pnpm build:js && pnpm build:postclean",
    "build:clean": "rm -rf dist",
    "build:js": "tsc",
